# All data lanes are free — no paid APIs required for v1

# ─── Required ───────────────────────────────────────────────────────────────
# Anthropic — for narrative generation
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Currents API — for media coverage lane
# Sign up free at https://currentsapi.services/en/register
CURRENTS_API_KEY=your_key_here

# ─── Snapshots (Upstash Redis) ───────────────────────────────────────────────
# Sign up free at https://upstash.com
UPSTASH_REDIS_REST_URL=your_upstash_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# Secret for daily snapshot cron — Vercel sends this as Authorization: Bearer
CRON_SECRET=your_secret_here

# ─── Optional ────────────────────────────────────────────────────────────────
# Cache TTL in seconds (default: 3600 = 1 hour)
CACHE_TTL_SECONDS=3600

# ─── Future: CLAWDGate (wallet gating) ───────────────────────────────────────
# Uncomment when adding paid tier
# CLAWD_GATE_CONTRACT=0xc22B7b983EC81523c969753c2385106835E8CfCE
# CLAWD_TOKEN_ADDRESS=0x9f86dB9fc6f7c9408e8Fda3Ff8ce4e78ac7a6b07
# CLAWD_MINIMUM_BALANCE=10000000
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id
