# ─── Required ───────────────────────────────────────────────────────────────
# Anthropic — for narrative generation
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Apify — covers Google Trends + Jobs lanes
# Sign up free at https://apify.com → Settings → Integrations → API token
APIFY_TOKEN=your_apify_token_here

# ─── Optional ────────────────────────────────────────────────────────────────
# Apify Actor IDs (defaults below work as of 2026)
# Override if you prefer a different actor from the Apify store
APIFY_TRENDS_ACTOR_ID=apify/google-trends-scraper
APIFY_JOBS_ACTOR_ID=sian.agency/ziprecruiter-jobs-scraper

# Cache TTL in seconds (default: 3600 = 1 hour)
CACHE_TTL_SECONDS=3600

# ─── Future: CLAWDGate (wallet gating) ───────────────────────────────────────
# Uncomment when adding paid tier
# CLAWD_GATE_CONTRACT=0xc22B7b983EC81523c969753c2385106835E8CfCE
# CLAWD_TOKEN_ADDRESS=0x9f86dB9fc6f7c9408e8Fda3Ff8ce4e78ac7a6b07
# CLAWD_MINIMUM_BALANCE=10000000
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id
